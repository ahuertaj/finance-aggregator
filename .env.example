# Copy to .env and fill in. Never commit .env.
DATABASE_URL="file:./prisma/dev.db"

# Plaid credentials (https://dashboard.plaid.com — Team Settings > Keys)
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"               # sandbox | production

# AES-256-GCM key (32 bytes hex) for encrypting Plaid access tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=""
